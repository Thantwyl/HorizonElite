PORT=3000
DATABASE_URL=postgresql://user:password@host:5432/database
FRONTEND_URL=http://localhost:5173
JWT_SECRET=change-this-secret
JWT_EXPIRES_IN=7d
BACKEND_PUBLIC_URL=http://localhost:3000

# Facebook Login
# Meta callback URL: http://localhost:3000/api/auth/facebook/callback
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret

# SMTP settings for registration verification emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="Horizon Elite <your-email@gmail.com>"

# Email verification link settings
EMAIL_VERIFICATION_TOKEN_TTL_MINUTES=60
EMAIL_VERIFICATION_TOKEN_SECRET=change-this-email-verification-token-secret

# E-ticket emails are queued after successful ticketing.
# 0 sends as soon as possible; 60 means about one hour after ticketing.
TICKET_EMAIL_DELAY_MINUTES=0

# Optional domain/mailbox validation settings
EMAIL_SMTP_VERIFY=false
EMAIL_SMTP_TIMEOUT_MS=8000
EMAIL_VERIFICATION_HELO_DOMAIN=horizonelite.local
EMAIL_VERIFICATION_FROM=verify@horizonelite.local
